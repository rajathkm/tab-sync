{
  "manifest_version": 3,
  "name": "Relay",
  "version": "1.1.16",
  "description": "Relay \u2014 cross-device tab sync, scoped per browser and profile.",
  "permissions": [
    "tabs",
    "storage",
    "contextMenus",
    "activeTab",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Relay"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "styles.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}